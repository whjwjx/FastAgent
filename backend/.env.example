# PostgreSQL Database Configuration
# The local development environment uses a Docker container.
# To start locally: docker-compose up -d

# Database URL format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# We created a new database 'fastagentdb' to avoid conflicts with 'testdb'
DATABASE_URL=postgresql://postgres:123456@localhost:15432/fastagentdb

# --- 核心大模型 (LLM) 配置 (火山引擎 Ark) ---
# API Key: 用于身份验证
LLM_API_KEY=your-api-key-here
# 基础 URL: 火山引擎 V3 接口地址
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 默认聊天模型 (Lite版): 用于日常轻量级对话和工具路由判断
LLM_MODEL=doubao-1-5-lite-32k-250115
# 高性能聊天模型 (Pro版): 用于长文本总结、复杂逻辑分析
LLM_MODEL_PRO=doubao-1-5-pro-32k-250115

# --- 向量模型 (Embedding) 配置 ---
# 向量模型 ID: 推荐使用 Doubao-multimodal 多模态向量模型 (2048维)
EMBEDDING_MODEL=doubao-embedding-vision-251215

# --- 外部工具与搜索配置 ---
# Tavily API Key: 用于 AI 助手执行联网搜索功能
TAVILY_API_KEY=your-tavily-key-here
