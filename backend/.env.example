# PostgreSQL Database Configuration
# The local development environment uses a Docker container.
# Container ID: 865cd6b46043bd0053c6bf2e18e5db3308134ef7e816a1c6464070c963c0c59c
# To start locally: docker-compose up -d

# Database URL format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# We created a new database 'fastAIstackdb' to avoid conflicts with 'testdb'
DATABASE_URL=postgresql://postgres:123456@localhost:15432/fastaistackdb
